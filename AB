#include <stdio.h>
#include <conio.h>
#include <stdlib.h>

void main()
{
    int month[12] = {31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31};
    int d, m, y, nd, nm, ny, ndays;

    printf("Enter the date, month, year (dd mm yyyy): ");
    scanf("%d%d%d", &d, &m, &y);

    if (y < 1812 || y > 2012)
    {
        printf("Invalid Input Year");
        exit(0);
    }

    if (m < 1 || m > 12)
    {
        printf("Invalid Input Month");
        exit(0);
    }

    ndays = month[m - 1];
    if (m == 2)
    {
        if (y % 100 == 0)
        {
            if (y % 400 == 0)
                ndays = 29;
        }
        else if (y % 4 == 0)
        {
            ndays = 29;
        }
    }

    if (d <= 0 || d > ndays)
    {
        printf("Invalid Input Day");
        exit(0);
    }

    nd = d + 1;
    nm = m;
    ny = y;

    if (nd > ndays)
    {
        nd = 1;
        nm++;
    }

    if (nm > 12)
    {
        nm = 1;
        ny++;
    }

    printf("\n Given date is %d:%d:%d", d, m, y);
    printf("\n Next day's date is %d:%d:%d", nd, nm, ny);
    getch();
}

